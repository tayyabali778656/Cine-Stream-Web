{
  "version": 2,
  "installCommand": "npm install --omit=dev",
  "buildCommand": "echo 'No build required'",
  "framework": null,
  "builds": [
    {
      "src": "serve.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "*.json",
          "*.xml",
          "*.txt",
          "*.png",
          "*.ico",
          "*.webmanifest",
          "images/**",
          "public/**",
          "middleware/**",
          "services/**",
          "utils/**",
          "scripts/**",
          "tayyab/**",
          "db.js",
          "config.js",
          "api.js",
          "admin.js",
          "app.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/_vercel/(.*)",
      "dest": "/_vercel/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "serve.js"
    },
    {
      "src": "/proxy",
      "dest": "serve.js"
    },
    {
      "src": "/iframe-proxy",
      "dest": "serve.js"
    },
    {
      "src": "/health",
      "dest": "serve.js"
    },
    {
      "src": "/watch/(.*)",
      "dest": "serve.js"
    },
    {
      "src": "/media/(.*)",
      "dest": "serve.js"
    },
    {
      "src": "/sitemap(.*)",
      "dest": "serve.js"
    },
    {
      "src": "/(index\\.html)?",
      "has": [
        {
          "type": "query",
          "key": "q"
        }
      ],
      "dest": "serve.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "serve.js"
    }
  ]
}