{
  "version": 2,
  "installCommand": "npm install --omit=dev",
  "buildCommand": "echo 'No build required'",
  "framework": null,

  "builds": [
    {
      "src": "serve.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "*.json",
          "*.xml",
          "*.txt",
          "*.png",
          "*.ico",
          "*.webmanifest",
          "images/**",
          "public/**",
          "middleware/**",
          "services/**",
          "utils/**",
          "scripts/**",
          "tayyab/**",
          "db.js",
          "config.js",
          "api.js",
          "admin.js",
          "app.js"
        ]
      }
    }
  ],

  "routes": [
    {
      "src": "/(.*)",
      "dest": "serve.js"
    }
  ]
}
